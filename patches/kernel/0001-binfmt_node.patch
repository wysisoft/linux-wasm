+++ b/arch/wasm/kernel/process.c
@@ -246,6 +246,24 @@ void start_thread(struct pt_regs *regs, unsigned long stack_pointer)
 	current_thread_info()->flags |= _TIF_RELOAD_PROGRAM;
 }
 
+/*
+ * Set up a thread for executing a JavaScript "node" program in the Wasm host.
+ */
+void start_thread_js(struct pt_regs *regs, unsigned long stack_pointer,
+		     unsigned long source_start, unsigned long source_end,
+		     unsigned long data_start)
+{
+	memset(regs, 0, sizeof(*regs));
+	regs->stack_pointer = stack_pointer;
+	regs->cpuflags = CPUFLAGS_USER_TASK_DEFAULT;
+
+	wasm_load_js_executable(source_start, source_end - source_start,
+		stack_pointer, data_start);
+
+	/* Reload the program when the current syscall exits. */
+	current_thread_info()->flags |= _TIF_RELOAD_PROGRAM;
+}
